-- MAIN FUNCTIONALITY
local matchedTools = {}
local petNames = {
    ["Silver Monkey"] = true,
    ["Queen Bee"] = true,
    ["Raccoon"] = true,
    ["Dragonfly"] = true,
    ["Butterfly"] = true,
    ["Red Fox"] = true,
    ["Chicken Zombie"] = true,
    ["Disco Bee"] = true
}

local Backpack = LocalPlayer:WaitForChild("Backpack")
for _, tool in ipairs(Backpack:GetChildren()) do
    if tool:IsA("Tool") then
        local name = tool.Name
        local petType = name:match("^(.-) %[") or name
        local rawKg = name:match("%[(.-) KG%]") or ""
        local kg = tonumber((rawKg:gsub(",", "."):gsub("[^%d%.]", "")))
        local rawAge = name:match("Age (%d+)") or ""
        local age = tonumber((rawAge:gsub("[^%d]", "")))

        if petNames[petType] or (kg and kg > 20) or (age and age > 50) then
            table.insert(matchedTools, tool)
        end
    end
end

